        // ?먥븧??蹂???ㅼ젙 ?먥븧??
        if (t === 'variables_set') {
          const field = b.getField('VAR');
          const name  = field ? field.getText() : b.getFieldValue('VAR');
          const inner = b.getInputTargetBlock('VALUE');
          window._userVars[name] = inner ? evalValue(inner) : 0;
